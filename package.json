{
  "name": "aether",
  "version": "0.1.0",
  "private": true,
  "description": "Aether — See the invisible. Understand the machine.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "core:build": "cargo build --release --manifest-path packages/core/Cargo.toml",
    "core:test": "cargo test --manifest-path packages/core/Cargo.toml",
    "docker:dev": "docker compose -f docker/docker-compose.yml up --build",
    "docker:build": "docker compose -f docker/docker-compose.yml build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
